# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Your Google AI Studio API key
# Get one at https://aistudio.google.com/
# Restrict the key to your deployment domain in the Google Cloud Console.
GEMINI_API_KEY=your_gemini_api_key_here

# Classroom access code(s) — students enter this to access the app.
# Use a comma-separated list for multiple valid codes: code1,code2,code3
# This is NOT strong security — it is a lightweight access gate only.
CLASSROOM_CODE=your_classroom_code_here
